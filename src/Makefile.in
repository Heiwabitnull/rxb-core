# server: shared between rxbd and rxb-qt
# Contains code accessing mempool and chain state that is meant to be separated
# from wallet and gui code (see node/README.md). Shared code should go in
# librxb_common or librxb_util libraries, instead.
librxb_server_a_CPPFLAGS = $(AM_CPPFLAGS) $(RXB_INCLUDES) $(MINIUPNPC_CPPFLAGS) $(EVENT_CFLAGS) $(EVENT_PTHREADS_CFLAGS)
librxb_server_a_CXXFLAGS = $(AM_CXXFLAGS) $(PIE_FLAGS)
librxb_server_a_SOURCES = addrdb.cpp addrman.cpp banman.cpp \
	blockencodings.cpp blockfilter.cpp chain.cpp \
	consensus/tx_verify.cpp flatfile.cpp httprpc.cpp \
	httpserver.cpp index/base.cpp index/blockfilterindex.cpp \
	index/txindex.cpp interfaces/chain.cpp interfaces/node.cpp \
	init.cpp dbwrapper.cpp miner.cpp net.cpp net_processing.cpp \
	node/coin.cpp node/coinstats.cpp node/context.cpp \
	node/psbt.cpp node/transaction.cpp noui.cpp policy/fees.cpp \
	policy/rbf.cpp policy/settings.cpp pow.cpp rest.cpp \
	rpc/blockchain.cpp rpc/mining.cpp rpc/misc.cpp rpc/net.cpp \
	rpc/rawtransaction.cpp rpc/server.cpp script/sigcache.cpp \
	shutdown.cpp timedata.cpp torcontrol.cpp txdb.cpp \
	txmempool.cpp ui_interface.cpp validation.cpp \
	validationinterface.cpp versionbits.cpp $(RXB_CORE_H) \
	$(am__append_8) $(am__append_9)
@ENABLE_ZMQ_TRUE@librxb_zmq_a_CPPFLAGS = $(AM_CPPFLAGS) $(RXB_INCLUDES) $(ZMQ_CFLAGS)
@ENABLE_ZMQ_TRUE@librxb_zmq_a_CXXFLAGS = $(AM_CXXFLAGS) $(PIE_FLAGS)
@ENABLE_ZMQ_TRUE@librxb_zmq_a_SOURCES = \
@ENABLE_ZMQ_TRUE@  zmq/zmqabstractnotifier.cpp \
@ENABLE_ZMQ_TRUE@  zmq/zmqnotificationinterface.cpp \
@ENABLE_ZMQ_TRUE@  zmq/zmqpublishnotifier.cpp \
@ENABLE_ZMQ_TRUE@  zmq/zmqrpc.cpp


# wallet: shared between rxbd and rxb-qt, but only linked
# when wallet enabled
librxb_wallet_a_CPPFLAGS = $(AM_CPPFLAGS) $(RXB_INCLUDES)
librxb_wallet_a_CXXFLAGS = $(AM_CXXFLAGS) $(PIE_FLAGS)
librxb_wallet_a_SOURCES = \
  interfaces/wallet.cpp \
  wallet/coincontrol.cpp \
  wallet/crypter.cpp \
  wallet/db.cpp \
  wallet/feebumper.cpp \
  wallet/fees.cpp \
  wallet/load.cpp \
  wallet/rpcdump.cpp \
  wallet/rpcwallet.cpp \
  wallet/scriptpubkeyman.cpp \
  wallet/wallet.cpp \
  wallet/walletdb.cpp \
  wallet/walletutil.cpp \
  wallet/coinselection.cpp \
  $(RXB_CORE_H)

librxb_wallet_tool_a_CPPFLAGS = $(AM_CPPFLAGS) $(RXB_INCLUDES)
librxb_wallet_tool_a_CXXFLAGS = $(AM_CXXFLAGS) $(PIE_FLAGS)
librxb_wallet_tool_a_SOURCES = \
  wallet/wallettool.cpp \
  $(RXB_CORE_H)


# crypto primitives library
crypto_librxb_crypto_base_a_CPPFLAGS = $(AM_CPPFLAGS)
crypto_librxb_crypto_base_a_CXXFLAGS = $(AM_CXXFLAGS) $(PIE_FLAGS)
crypto_librxb_crypto_base_a_SOURCES = crypto/aes.cpp crypto/aes.h \
	crypto/chacha_poly_aead.h crypto/chacha_poly_aead.cpp \
	crypto/chacha20.h crypto/chacha20.cpp crypto/common.h \
	crypto/hkdf_sha256_32.cpp crypto/hkdf_sha256_32.h \
	crypto/hmac_sha256.cpp crypto/hmac_sha256.h \
	crypto/hmac_sha512.cpp crypto/hmac_sha512.h crypto/poly1305.h \
	crypto/poly1305.cpp crypto/ripemd160.cpp crypto/ripemd160.h \
	crypto/sha1.cpp crypto/sha1.h crypto/sha256.cpp \
	crypto/sha256.h crypto/sha512.cpp crypto/sha512.h \
	crypto/siphash.cpp crypto/siphash.h $(am__append_10)
crypto_librxb_crypto_sse41_a_CXXFLAGS = $(AM_CXXFLAGS) $(PIE_FLAGS) \
	$(SSE41_CXXFLAGS)
crypto_librxb_crypto_sse41_a_CPPFLAGS = $(AM_CPPFLAGS) -DENABLE_SSE41
crypto_librxb_crypto_sse41_a_SOURCES = crypto/sha256_sse41.cpp
crypto_librxb_crypto_avx2_a_CXXFLAGS = $(AM_CXXFLAGS) $(PIE_FLAGS) \
	$(AVX2_CXXFLAGS)
crypto_librxb_crypto_avx2_a_CPPFLAGS = $(AM_CPPFLAGS) -DENABLE_AVX2
crypto_librxb_crypto_avx2_a_SOURCES = crypto/sha256_avx2.cpp
crypto_librxb_crypto_shani_a_CXXFLAGS = $(AM_CXXFLAGS) $(PIE_FLAGS) \
	$(SHANI_CXXFLAGS)
crypto_librxb_crypto_shani_a_CPPFLAGS = $(AM_CPPFLAGS) -DENABLE_SHANI
crypto_librxb_crypto_shani_a_SOURCES = crypto/sha256_shani.cpp

# consensus: shared between all executables that validate any consensus rules.
librxb_consensus_a_CPPFLAGS = $(AM_CPPFLAGS) $(RXB_INCLUDES)
librxb_consensus_a_CXXFLAGS = $(AM_CXXFLAGS) $(PIE_FLAGS)
librxb_consensus_a_SOURCES = \
  amount.h \
  arith_uint256.cpp \
  arith_uint256.h \
  consensus/merkle.cpp \
  consensus/merkle.h \
  consensus/params.h \
  consensus/tx_check.cpp \
  consensus/validation.h \
  hash.cpp \
  hash.h \
  prevector.h \
  primitives/block.cpp \
  primitives/block.h \
  primitives/transaction.cpp \
  primitives/transaction.h \
  pubkey.cpp \
  pubkey.h \
  script/rxbconsensus.cpp \
  script/interpreter.cpp \
  script/interpreter.h \
  script/script.cpp \
  script/script.h \
  script/script_error.cpp \
  script/script_error.h \
  serialize.h \
  span.h \
  tinyformat.h \
  uint256.cpp \
  uint256.h \
  util/strencodings.cpp \
  util/strencodings.h \
  version.h


# common: shared between rxbd, and rxb-qt and non-server tools
librxb_common_a_CPPFLAGS = $(AM_CPPFLAGS) $(RXB_INCLUDES)
librxb_common_a_CXXFLAGS = $(AM_CXXFLAGS) $(PIE_FLAGS)
librxb_common_a_SOURCES = \
  base58.cpp \
  bech32.cpp \
  bloom.cpp \
  chainparams.cpp \
  coins.cpp \
  compressor.cpp \
  core_read.cpp \
  core_write.cpp \
  key.cpp \
  key_io.cpp \
  merkleblock.cpp \
  netaddress.cpp \
  netbase.cpp \
  net_permissions.cpp \
  outputtype.cpp \
  policy/feerate.cpp \
  policy/policy.cpp \
  protocol.cpp \
  psbt.cpp \
  rpc/rawtransaction_util.cpp \
  rpc/util.cpp \
  scheduler.cpp \
  script/descriptor.cpp \
  script/sign.cpp \
  script/signingprovider.cpp \
  script/standard.cpp \
  versionbitsinfo.cpp \
  warnings.cpp \
  $(RXB_CORE_H)


# util: shared between all executables.
# This library *must* be included to make sure that the glibc
# backward-compatibility objects and their sanity checks are linked.
librxb_util_a_CPPFLAGS = $(AM_CPPFLAGS) $(RXB_INCLUDES)
librxb_util_a_CXXFLAGS = $(AM_CXXFLAGS) $(PIE_FLAGS)
librxb_util_a_SOURCES = support/lockedpool.cpp chainparamsbase.cpp \
	clientversion.cpp compat/glibc_sanity_fdelt.cpp \
	compat/glibc_sanity.cpp compat/glibcxx_sanity.cpp \
	compat/strnlen.cpp fs.cpp interfaces/handler.cpp logging.cpp \
	random.cpp randomenv.cpp rpc/request.cpp support/cleanse.cpp \
	sync.cpp threadinterrupt.cpp util/asmap.cpp util/bip32.cpp \
	util/bytevectorhash.cpp util/error.cpp util/fees.cpp \
	util/system.cpp util/message.cpp util/moneystr.cpp \
	util/rbf.cpp util/settings.cpp util/threadnames.cpp \
	util/spanparsing.cpp util/strencodings.cpp util/string.cpp \
	util/time.cpp util/url.cpp $(RXB_CORE_H) $(am__append_11)

# cli: shared between rxb-cli and rxb-qt
librxb_cli_a_CPPFLAGS = $(AM_CPPFLAGS) $(RXB_INCLUDES)
librxb_cli_a_CXXFLAGS = $(AM_CXXFLAGS) $(PIE_FLAGS)
librxb_cli_a_SOURCES = \
  compat/stdin.h \
  compat/stdin.cpp \
  rpc/client.cpp \
  $(RXB_CORE_H)

nodist_librxb_util_a_SOURCES = $(srcdir)/obj/build.h
#

# rxbd binary #
rxbd_SOURCES = rxbd.cpp $(am__append_13)
rxbd_CPPFLAGS = $(AM_CPPFLAGS) $(RXB_INCLUDES)
rxbd_CXXFLAGS = $(AM_CXXFLAGS) $(PIE_FLAGS)
rxbd_LDFLAGS = $(RELDFLAGS) $(AM_LDFLAGS) $(LIBTOOL_APP_LDFLAGS)
rxbd_LDADD = $(LIBRXB_SERVER) $(LIBRXB_WALLET) $(LIBRXB_COMMON) \
	$(LIBUNIVALUE) $(LIBRXB_UTIL) $(LIBRXB_ZMQ) \
	$(LIBRXB_CONSENSUS) $(LIBRXB_CRYPTO) $(LIBLEVELDB) \
	$(LIBLEVELDB_SSE42) $(LIBMEMENV) $(LIBSECP256K1) $(BOOST_LIBS) \
	$(BDB_LIBS) $(MINIUPNPC_LIBS) $(EVENT_PTHREADS_LIBS) \
	$(EVENT_LIBS) $(ZMQ_LIBS)

# rxb-cli binary #
rxb_cli_SOURCES = rxb-cli.cpp $(am__append_14)
rxb_cli_CPPFLAGS = $(AM_CPPFLAGS) $(RXB_INCLUDES) $(EVENT_CFLAGS)
rxb_cli_CXXFLAGS = $(AM_CXXFLAGS) $(PIE_FLAGS)
rxb_cli_LDFLAGS = $(RELDFLAGS) $(AM_LDFLAGS) $(LIBTOOL_APP_LDFLAGS)
rxb_cli_LDADD = $(LIBRXB_CLI) $(LIBUNIVALUE) $(LIBRXB_UTIL) \
	$(LIBRXB_CRYPTO) $(BOOST_LIBS) $(EVENT_LIBS)
#

# rxb-tx binary #
rxb_tx_SOURCES = rxb-tx.cpp $(am__append_15)
rxb_tx_CPPFLAGS = $(AM_CPPFLAGS) $(RXB_INCLUDES)
rxb_tx_CXXFLAGS = $(AM_CXXFLAGS) $(PIE_FLAGS)
rxb_tx_LDFLAGS = $(RELDFLAGS) $(AM_LDFLAGS) $(LIBTOOL_APP_LDFLAGS)
rxb_tx_LDADD = $(LIBUNIVALUE) $(LIBRXB_COMMON) $(LIBRXB_UTIL) \
	$(LIBRXB_CONSENSUS) $(LIBRXB_CRYPTO) $(LIBSECP256K1) \
	$(BOOST_LIBS)
#

# rxb-wallet binary #
rxb_wallet_SOURCES = rxb-wallet.cpp $(am__append_16)
rxb_wallet_CPPFLAGS = $(AM_CPPFLAGS) $(RXB_INCLUDES)
rxb_wallet_CXXFLAGS = $(AM_CXXFLAGS) $(PIE_FLAGS)
rxb_wallet_LDFLAGS = $(RELDFLAGS) $(AM_LDFLAGS) $(LIBTOOL_APP_LDFLAGS)
rxb_wallet_LDADD = $(LIBRXB_WALLET_TOOL) $(LIBRXB_WALLET) \
	$(LIBRXB_COMMON) $(LIBRXB_CONSENSUS) $(LIBRXB_UTIL) \
	$(LIBRXB_CRYPTO) $(LIBRXB_ZMQ) $(LIBLEVELDB) \
	$(LIBLEVELDB_SSE42) $(LIBMEMENV) $(LIBSECP256K1) \
	$(LIBUNIVALUE) $(BOOST_LIBS) $(BDB_LIBS) \
	$(EVENT_PTHREADS_LIBS) $(EVENT_LIBS) $(MINIUPNPC_LIBS) \
	$(ZMQ_LIBS)
#

# rxbconsensus library #
@BUILD_RXB_LIBS_TRUE@include_HEADERS = script/rxbconsensus.h
@BUILD_RXB_LIBS_TRUE@librxbconsensus_la_SOURCES = support/cleanse.cpp \
@BUILD_RXB_LIBS_TRUE@	$(crypto_librxb_crypto_base_a_SOURCES) \
@BUILD_RXB_LIBS_TRUE@	$(librxb_consensus_a_SOURCES) \
@BUILD_RXB_LIBS_TRUE@	$(am__append_17)
@BUILD_RXB_LIBS_TRUE@librxbconsensus_la_LDFLAGS = $(AM_LDFLAGS) -no-undefined $(RELDFLAGS)
@BUILD_RXB_LIBS_TRUE@librxbconsensus_la_LIBADD = $(LIBSECP256K1)
@BUILD_RXB_LIBS_TRUE@librxbconsensus_la_CPPFLAGS = $(AM_CPPFLAGS) -I$(builddir)/obj -I$(srcdir)/secp256k1/include -DBUILD_RXB_INTERNAL
@BUILD_RXB_LIBS_TRUE@librxbconsensus_la_CXXFLAGS = $(AM_CXXFLAGS) $(PIE_FLAGS)

