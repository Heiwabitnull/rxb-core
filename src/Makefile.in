DIST_SUBDIRS = secp256k1 univalue
AM_LDFLAGS = $(PTHREAD_CFLAGS) $(LIBTOOL_LDFLAGS) $(HARDENED_LDFLAGS) \
	$(GPROF_LDFLAGS) $(SANITIZER_LDFLAGS) $(am__append_12)
AM_CXXFLAGS = $(DEBUG_CXXFLAGS) $(HARDENED_CXXFLAGS) $(WARN_CXXFLAGS) $(NOWARN_CXXFLAGS) $(ERROR_CXXFLAGS) $(GPROF_CXXFLAGS) $(SANITIZER_CXXFLAGS)
AM_CPPFLAGS = $(DEBUG_CPPFLAGS) $(HARDENED_CPPFLAGS)
AM_LIBTOOLFLAGS = --preserve-dup-deps

# Make is not made aware of per-object dependencies to avoid limiting building parallelization
# But to build the less dependent modules first, we manually select their order here:
EXTRA_LIBRARIES = $(LIBRXB_CRYPTO) $(LIBRXB_UTIL) $(LIBRXB_COMMON) \
	$(LIBRXB_CONSENSUS) $(LIBRXB_SERVER) $(LIBRXB_CLI) \
	$(LIBRXB_WALLET) $(LIBRXB_WALLET_TOOL) $(LIBRXB_ZMQ) \
	$(am__append_18) $(am__append_25) $(am__append_27) \
	$(am__append_29) $(am__append_40)
@EMBEDDED_UNIVALUE_FALSE@LIBUNIVALUE = $(UNIVALUE_LIBS)
@EMBEDDED_UNIVALUE_TRUE@LIBUNIVALUE = univalue/libunivalue.la
RXB_INCLUDES = -I$(builddir) $(BDB_CPPFLAGS) $(BOOST_CPPFLAGS) \
	$(LEVELDB_CPPFLAGS) -I$(srcdir)/secp256k1/include \
	$(UNIVALUE_CFLAGS)
LIBRXB_SERVER = librxb_server.a
LIBRXB_COMMON = librxb_common.a
LIBRXB_CONSENSUS = librxb_consensus.a
LIBRXB_CLI = librxb_cli.a
LIBRXB_UTIL = librxb_util.a
LIBRXB_CRYPTO_BASE = crypto/librxb_crypto_base.a
LIBRXBQT = qt/librxbqt.a
LIBSECP256K1 = secp256k1/libsecp256k1.la
@ENABLE_ZMQ_TRUE@LIBRXB_ZMQ = librxb_zmq.a
@BUILD_RXB_LIBS_TRUE@LIBRXBCONSENSUS = librxbconsensus.la
@ENABLE_WALLET_TRUE@LIBRXB_WALLET = librxb_wallet.a
@ENABLE_WALLET_TRUE@LIBRXB_WALLET_TOOL = librxb_wallet_tool.a
LIBRXB_CRYPTO = $(LIBRXB_CRYPTO_BASE) $(am__append_1) $(am__append_2) \
	$(am__append_3)
@ENABLE_SSE41_TRUE@LIBRXB_CRYPTO_SSE41 = crypto/librxb_crypto_sse41.a
@ENABLE_AVX2_TRUE@LIBRXB_CRYPTO_AVX2 = crypto/librxb_crypto_avx2.a
@ENABLE_SHANI_TRUE@LIBRXB_CRYPTO_SHANI = crypto/librxb_crypto_shani.a
lib_LTLIBRARIES = $(LIBRXBCONSENSUS)
